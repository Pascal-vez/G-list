# Échapper chaque $ avec \ (ex: \$2a\$12\$...)
VITE_ADMIN_HASH=\$2a\$12\$your_bcrypt_hash_here

# Mot de passe admin en clair (prototype uniquement, si VITE_ADMIN_HASH absent)
# VITE_ADMIN_PASSWORD=glist2026

# URL de l'API backend (vide = mode local / localStorage)
# VITE_API_URL=http://localhost:3001/api

# URL publique du site (SEO, partage)
# VITE_SITE_URL=https://g-list.gn

# Assistant G-Bot : mode local (base de connaissances intégrée, sans clé API)
# Pour brancher un LLM plus tard : VITE_BOT_API_URL=https://votre-api/bot
